[gd_scene load_steps=2 format=3 uid="uid://game_lobby"]

[ext_resource type="Script" path="res://scripts/ui/lobby_ui.gd" id="1_lobby"]

[node name="GameLobby" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_lobby")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
color = Color(0.12, 0.12, 0.20, 1)

[node name="TopBar" type="HBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 2
anchor_top = 0.0
anchor_right = 1.0
offset_left = 4.0
offset_top = 4.0
offset_right = -4.0
offset_bottom = 28.0

[node name="Title" type="Label" parent="TopBar"]
layout_mode = 2
text = "山野小村 · 联机大厅"
horizontal_alignment = 0

[node name="RoomCode" type="Label" parent="TopBar"]
layout_mode = 2
text = "房间: ---"
horizontal_alignment = 1
size_flags_horizontal = 3

[node name="ConnectionStatus" type="HBoxContainer" parent="TopBar"]
layout_mode = 2
script = ExtResource("res://scripts/ui/connection_status.gd")

[node name="MainArea" type="HBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 4.0
offset_top = 32.0
offset_right = -4.0
offset_bottom = -4.0
add_theme_constant_override("separation", 8)

[node name="LeftPanel" type="VBoxContainer" parent="MainArea"]
layout_mode = 2
custom_minimum_size = Vector2(220, 0)
add_theme_constant_override("separation", 8)

[node name="PlayerListLabel" type="Label" parent="MainArea/LeftPanel"]
layout_mode = 2
text = "玩家列表"

[node name="PlayerList" type="VBoxContainer" parent="MainArea/LeftPanel"]
layout_mode = 2
size_flags_vertical = 3
script = ExtResource("res://scripts/ui/player_list.gd")

[node name="SettingsSection" type="VBoxContainer" parent="MainArea/LeftPanel"]
layout_mode = 2
add_theme_constant_override("separation", 4)

[node name="SettingsLabel" type="Label" parent="MainArea/LeftPanel/SettingsSection"]
layout_mode = 2
text = "设置"

[node name="MoneyMode" type="OptionButton" parent="MainArea/LeftPanel/SettingsSection"]
layout_mode = 2
text = "金钱模式"
item_count = 2
selected = 0
popup/item_0/text = "共享钱包"
popup/item_0/id = 0
popup/item_1/text = "独立财务"
popup/item_1/id = 1

[node name="ReadyBtn" type="Button" parent="MainArea/LeftPanel"]
layout_mode = 2
text = "准备"
custom_minimum_size = Vector2(0, 36)

[node name="RightPanel" type="VBoxContainer" parent="MainArea"]
layout_mode = 2
size_flags_horizontal = 3
add_theme_constant_override("separation", 8)

[node name="ChatPanel" type="Control" parent="MainArea/RightPanel"]
layout_mode = 2
size_flags_vertical = 3
script = ExtResource("res://scripts/ui/chat_panel.gd")

[node name="BottomBar" type="HBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 12
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 4.0
offset_top = -36.0
offset_right = -4.0
offset_bottom = -4.0
alignment = 2

[node name="StartBtn" type="Button" parent="BottomBar"]
layout_mode = 2
text = "开始游戏"
custom_minimum_size = Vector2(120, 32)
disabled = true

[connection signal="pressed" from="MainArea/LeftPanel/ReadyBtn" to="." method="_on_ready_toggle"]
[connection signal="pressed" from="BottomBar/StartBtn" to="." method="_on_start_game"]